{
  "name": "morse-codetranslator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node ./scripts/sync-uploads.mjs",
    "prebuild": "node ./scripts/sync-uploads.mjs",
    "prestart": "node ./scripts/sync-uploads.mjs",
    "preexport": "node ./scripts/sync-uploads.mjs",
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:test": "NEXT_PUBLIC_BASE_PATH=/test NEXT_PUBLIC_NOINDEX=true next build",
    "start": "next start -p 3000",
    "export": "next build",
    "lint": "next lint"
  },
  "dependencies": {
    "lamejs": "^1.2.1",
    "next": "^16.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2"
  }
}
